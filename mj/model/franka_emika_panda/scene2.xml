<mujoco model="panda scene">
  
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="red_cube" pos="0.55 0.0 0.03">
        <freejoint/>
        <geom type="box" size="0.03 0.03 0.03" rgba="1 0 0 1" mass="0.1"/>
    </body>


    <!-- Front Camera -->
    <!--鸟瞰：pos="0.4 0.0 1.7" xyaxes="0 1 0 -1 0 0"   正面：pos="1.2 0.0 0.8" xyaxes="0 1 0 0 0.5 1"-->
    <camera name="front_cam" pos="0.4 0.0 1.7" xyaxes="0 1 0 -1 0 0"/>

    <!-- Top Camera -->
    <!--<camera name="top_cam" pos="0.5 0.0 1.2" xyaxes="1 0 0 0 1 0"/>-->

  </worldbody>

  <!--
      注意这里keyframe中的qpos，一定要确定qpos的维度，也就是自由度
      原始的panda的qpos长度＝model.nq, 是9, 就是panda(7) + gripper(2), 所以在panda.xml中的qpos长度为9
      我们在scene中加入了cube, 此时qpos长度变成了16，增加的7个是cube的x y z qw qx qy qz
  -->
  <keyframe>
    <key name="home" qpos="0 0.3 0 -1.57079 0 2.0 -0.7853 0.04 0.04 0.55 0.0 0.03 1 0 0 0"
      ctrl="0 0.3 0 -1.57079 0 2.0 -0.7853 0.04"/>

  </keyframe>
</mujoco>
